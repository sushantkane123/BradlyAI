# ============================================================================
# BradlyAI — Production environment template
# Copy to:   ./.env (project root)
# Then run:  ./deploy/start.sh
# ============================================================================

# ---------- Application ----------
APP_NAME="BradlyAI - Driverless SOC & Automated Incident Response"
APP_VERSION="2.1.0-PRO"
ENVIRONMENT=production
HOST=0.0.0.0
PORT=8000

# ---------- Database ----------
# For local single-host: keep SQLite. For multi-host or HA: use Postgres.
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/bradlyai
DATABASE_URL=sqlite+aiosqlite:////opt/bradlyai/data/bradlyai_soc.db

# ---------- AI / LLM ----------
LLM_PROVIDER=groq
GROQ_API_KEY=gsk_replace_me
OPENAI_API_KEY=sk-replace_me
DEFAULT_AI_MODEL=gpt-4-turbo-preview

# ---------- Autonomous SOC tuning ----------
AUTO_CONTAINMENT_THRESHOLD=0.85
LIVE_SIMULATION_WORKER_ACTIVE=true
SIMULATION_INTERVAL_SECONDS=30

# ---------- Rate limiting ----------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=300
RATE_LIMIT_WINDOW_SECONDS=60

# ---------- CORS ----------
# Comma-separated list of allowed origins for the AI Copilot
CORS_ALLOWED_ORIGINS=https://bradlyai.example.com

# ---------- Logging ----------
LOG_LEVEL=info
